// ─────────────────────────────────────────────────────────────
// 3D Print Manager — Schema do Banco de Dados (Prisma)
// ─────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────────────────────

enum Role {
  ADMIN  // Super admin do sistema
  USER   // Assinante normal
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  PAST_DUE
  CANCELED
  UNPAID
}

enum QuoteStatus {
  DRAFT
  SENT
  VIEWED
  APPROVED
  REJECTED
  EXPIRED
}

enum PrintStatus {
  QUEUED
  STARTED
  PAUSED
  RESUMED
  CANCELLED
  COMPLETED
}

enum PrintPauseReason {
  FILAMENT_EMPTY
  ADHESION_FAILURE
  POWER_OUTAGE
  MANUAL_PAUSE
  Z_OFFSET_ISSUE
  NOZZLE_CLOG
  OTHER
}

enum PrintCancelReason {
  PRINT_FAILURE
  CLIENT_CANCELLED
  MODEL_ERROR
  FILAMENT_EMPTY
  EQUIPMENT_ISSUE
  OTHER
}

enum KanbanColumn {
  WAITING      // Aguardando Resposta
  APPROVED     // Aprovado
  PRINTING     // Em Produção
  POST_PROD    // Pós-Produção
  READY        // Pronto para Entrega
  DELIVERED    // Entregue / Concluído
  CANCELLED    // Cancelado
}

enum ExpenseCategory {
  FILAMENT
  PRINTER_PARTS
  ENERGY
  MARKETING
  TOOLS
  PACKAGING
  SHIPPING
  OTHER
}

enum FilamentType {
  PLA
  PETG
  ABS
  ASA
  TPU
  NYLON
  RESIN
  OTHER
}

// ─────────────────────────────────────────────────────────────
// USUÁRIOS & AUTH
// ─────────────────────────────────────────────────────────────

model User {
  id            String   @id @default(cuid())
  name          String?
  email         String   @unique
  emailVerified DateTime?
  password      String?
  image         String?  // URL da logo/avatar no MinIO
  role          Role     @default(USER)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Perfil comercial
  businessName  String?
  whatsapp      String?
  city          String?
  logoUrl       String?

  // Stripe
  stripeCustomerId     String?  @unique
  stripeSubscriptionId String?  @unique
  subscriptionStatus   SubscriptionStatus @default(TRIAL)
  trialEndsAt          DateTime?
  currentPeriodEnd     DateTime?

  // WhatsApp (Evolution API) - instância do usuário
  evolutionInstance    String?
  evolutionConnected   Boolean  @default(false)

  // InfinityPay
  infinitypayApiKey    String?
  infinitypayEnabled   Boolean  @default(false)

  // Configurações gerais
  settings             UserSettings?
  whatsappTemplates    WhatsappTemplate[]

  // Dados do negócio
  printers     Printer[]
  clients      Client[]
  quotes       Quote[]
  kanbanCards  KanbanCard[]
  expenses     Expense[]
  revenues     Revenue[]
  filaments    Filament[]
  pieceLibrary PieceTemplate[]

  accounts Account[]
  sessions Session[]
}

// NextAuth.js - Accounts (OAuth providers)
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

// NextAuth.js - Sessions
model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// NextAuth.js - Verification tokens (email)
model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─────────────────────────────────────────────────────────────
// CONFIGURAÇÕES DO USUÁRIO
// ─────────────────────────────────────────────────────────────

model UserSettings {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Custos gerais
  energyCostKwh        Float  @default(0.75)  // R$/kWh
  defaultProfitMargin  Float  @default(30)    // %
  paintingHourlyRate   Float  @default(0)     // R$/hora

  // Automações — toggles
  autoDeductStock           Boolean @default(true)
  lowStockAlertEnabled      Boolean @default(true)
  quoteExpirationEnabled    Boolean @default(true)
  quoteExpirationDays       Int     @default(5)
  quoteReminderEnabled      Boolean @default(true)
  paymentLinkEnabled        Boolean @default(false)
  paymentDepositPercent     Float   @default(50) // %
  whatsappAutoEnabled       Boolean @default(false)
  silentHoursEnabled        Boolean @default(false)
  silentHoursStart          String  @default("22:00")
  silentHoursEnd            String  @default("08:00")
  autoReplyEnabled          Boolean @default(false)
  autoReplyMessage          String? @db.Text
  followupEnabled           Boolean @default(false)
  followup7DaysEnabled      Boolean @default(true)
  followup30DaysEnabled     Boolean @default(true)
  npsEnabled                Boolean @default(false)
  npsDaysAfterDelivery       Int     @default(7)
  viewTrackingEnabled       Boolean @default(true)
  portfolioEnabled          Boolean @default(true)
  portfolioLeadFormEnabled  Boolean @default(false)
  portfolioTestimonialsEnabled Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─────────────────────────────────────────────────────────────
// TEMPLATES DE MENSAGENS WHATSAPP
// ─────────────────────────────────────────────────────────────

model WhatsappTemplate {
  id       String      @id @default(cuid())
  userId   String
  user     User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  column   KanbanColumn
  message  String      @db.Text
  enabled  Boolean     @default(true)
  isDefault Boolean    @default(false)

  @@unique([userId, column])
}

// ─────────────────────────────────────────────────────────────
// IMPRESSORAS
// ─────────────────────────────────────────────────────────────

model Printer {
  id              String  @id @default(cuid())
  userId          String
  user            User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  name            String  // Ex: "Bambu Lab X1C"
  model           String? // Ex: "X1C"
  powerWatts      Float   // Consumo em watts
  purchasePrice   Float   // Preço de compra em R$
  estimatedHours  Float   @default(5000)  // Vida útil em horas
  monthlyMaintenance Float @default(0)   // Custo mensal de manutenção R$
  active          Boolean @default(true)

  // Calculado automaticamente
  // costPerHour = (purchasePrice / estimatedHours) + (monthlyMaintenance / horasMes)

  // Estatísticas
  totalHours      Float   @default(0)
  totalPrints     Int     @default(0)
  successCount    Int     @default(0)
  failureCount    Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  quotes     Quote[]
  printLogs  PrintLog[]
}

// ─────────────────────────────────────────────────────────────
// CLIENTES
// ─────────────────────────────────────────────────────────────

model Client {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  whatsapp  String?
  email     String?
  city      String?
  notes     String?  @db.Text
  tags      String[] // Ex: ["VIP", "atacado"]
  npsScore  Float?   // Última nota NPS

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  quotes     Quote[]
  kanbanCards KanbanCard[]
}

// ─────────────────────────────────────────────────────────────
// ORÇAMENTOS
// ─────────────────────────────────────────────────────────────

model Quote {
  id          String      @id @default(cuid())
  userId      String
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  clientId    String?
  client      Client?     @relation(fields: [clientId], references: [id])
  printerId   String?
  printer     Printer?    @relation(fields: [printerId], references: [id])

  // Dados da peça
  pieceName       String
  description     String?  @db.Text
  photoUrl        String?  // URL no MinIO

  // Inputs do cálculo
  filamentGrams   Float    // Peso em gramas
  printHours      Float    // Horas de impressão
  profitMargin    Float    // % de lucro
  paintingHours   Float    @default(0)
  filamentId      String?
  filament        Filament? @relation(fields: [filamentId], references: [id])

  // Resultados calculados
  filamentCost    Float    // R$
  energyCost      Float    // R$
  printerCost     Float    // R$
  productionCost  Float    // Subtotal de produção
  profitAmount    Float    // Valor do lucro
  paintingCost    Float    @default(0)
  totalPrice      Float    // Total final

  // Status e aprovação
  status          QuoteStatus @default(DRAFT)
  publicToken     String?     @unique // Para link público
  expiresAt       DateTime?
  approvedAt      DateTime?
  rejectedAt      DateTime?
  viewCount       Int         @default(0)
  lastViewedAt    DateTime?

  // Versões do orçamento
  versions        QuoteVersion[]

  // Pagamento
  paymentLinkUrl  String?
  depositPaid     Boolean  @default(false)
  depositAmount   Float?

  // PDF
  pdfUrl          String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  kanbanCard KanbanCard?
}

model QuoteVersion {
  id          String  @id @default(cuid())
  quoteId     String
  quote       Quote   @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  label       String  // Ex: "Básico", "Com Pintura", "Premium"
  description String?
  totalPrice  Float
  details     Json    // Snapshot dos custos desta versão
  order       Int     @default(0)

  createdAt DateTime @default(now())
}

// ─────────────────────────────────────────────────────────────
// CRM KANBAN
// ─────────────────────────────────────────────────────────────

model KanbanCard {
  id        String       @id @default(cuid())
  userId    String
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  quoteId   String?      @unique
  quote     Quote?       @relation(fields: [quoteId], references: [id])
  clientId  String?
  client    Client?      @relation(fields: [clientId], references: [id])

  column    KanbanColumn @default(WAITING)
  order     Int          @default(0)
  dueDate   DateTime?
  notes     String?      @db.Text
  tags      String[]
  photoUrl  String?

  // Logs de impressão associados
  printLogs PrintLog[]

  // Histórico de mensagens WhatsApp
  whatsappMessages WhatsappMessage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  columnHistory KanbanHistory[]
}

model KanbanHistory {
  id         String       @id @default(cuid())
  cardId     String
  card       KanbanCard   @relation(fields: [cardId], references: [id], onDelete: Cascade)
  fromColumn KanbanColumn?
  toColumn   KanbanColumn
  movedAt    DateTime     @default(now())
}

// ─────────────────────────────────────────────────────────────
// FILA DE IMPRESSÃO / PRINT LOGS
// ─────────────────────────────────────────────────────────────

model PrintLog {
  id          String       @id @default(cuid())
  userId      String
  cardId      String?
  card        KanbanCard?  @relation(fields: [cardId], references: [id])
  printerId   String?
  printer     Printer?     @relation(fields: [printerId], references: [id])
  filamentId  String?
  filament    Filament?    @relation(fields: [filamentId], references: [id])

  status          PrintStatus      @default(QUEUED)
  estimatedHours  Float
  startedAt       DateTime?
  completedAt     DateTime?
  pausedAt        DateTime?
  totalPausedMin  Int              @default(0) // Minutos totais pausado
  pauseReason     PrintPauseReason?
  cancelReason    PrintCancelReason?
  cancelNote      String?

  photoStart      String?  // Foto ao iniciar
  photoEnd        String?  // Foto ao concluir

  // Notificação ao cliente ao cancelar
  clientNotified  Boolean  @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  statusHistory PrintStatusHistory[]
}

model PrintStatusHistory {
  id         String      @id @default(cuid())
  printLogId String
  printLog   PrintLog    @relation(fields: [printLogId], references: [id], onDelete: Cascade)
  status     PrintStatus
  reason     String?
  note       String?
  changedAt  DateTime    @default(now())
}

// ─────────────────────────────────────────────────────────────
// ESTOQUE DE FILAMENTO
// ─────────────────────────────────────────────────────────────

model Filament {
  id            String       @id @default(cuid())
  userId        String
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  name          String       // Ex: "PLA Branco Polymaker"
  brand         String?
  type          FilamentType @default(PLA)
  color         String?      // Nome da cor
  colorHex      String?      // Ex: "#FFFFFF"
  qrCode        String?      @unique // Para scanner
  purchasedGrams Float       // Gramas compradas originalmente
  currentGrams  Float        // Saldo atual
  costPerKg     Float        // R$/kg
  lowStockAlert Float        @default(200) // Alerta em gramas
  rating        Int?         // 1-5
  ratingNote    String?
  supplierId    String?
  supplier      Supplier?    @relation(fields: [supplierId], references: [id])
  active        Boolean      @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  quotes     Quote[]
  printLogs  PrintLog[]
}

model Supplier {
  id       String  @id @default(cuid())
  userId   String
  name     String
  website  String?
  notes    String?

  filaments Filament[]

  createdAt DateTime @default(now())
}

// ─────────────────────────────────────────────────────────────
// BIBLIOTECA DE PEÇAS (Templates)
// ─────────────────────────────────────────────────────────────

model PieceTemplate {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name          String
  description   String?
  photoUrl      String?
  filamentGrams Float
  printHours    Float
  printingNotes String?  @db.Text // Dicas técnicas de impressão
  printerId     String?
  filamentType  FilamentType?

  // Métricas
  quoteCount    Int      @default(0)
  approvedCount Int      @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─────────────────────────────────────────────────────────────
// FINANCEIRO
// ─────────────────────────────────────────────────────────────

model Expense {
  id             String          @id @default(cuid())
  userId         String
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  category       ExpenseCategory
  customCategory String?         // Label personalizado quando category = OTHER
  description    String
  amount         Float
  date           DateTime
  receiptUrl     String?
  notes          String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Revenue {
  id              String     @id @default(cuid())
  userId          String
  user            User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  cardId          String?
  description     String
  grossAmount     Float      // Valor cobrado do cliente
  productionCost  Float      // Custo de produção (do orçamento)
  netProfit       Float      // Lucro líquido
  date            DateTime
  notes           String?

  createdAt DateTime @default(now())
}

// ─────────────────────────────────────────────────────────────
// WHATSAPP MESSAGES LOG
// ─────────────────────────────────────────────────────────────

model WhatsappMessage {
  id        String     @id @default(cuid())
  cardId    String?
  card      KanbanCard? @relation(fields: [cardId], references: [id])
  to        String     // Número do destinatário
  message   String     @db.Text
  sent      Boolean    @default(false)
  sentAt    DateTime?
  error     String?
  template  String?    // Nome do template usado

  createdAt DateTime @default(now())
}

// ─────────────────────────────────────────────────────────────
// PORTFÓLIO
// ─────────────────────────────────────────────────────────────

model PortfolioItem {
  id          String  @id @default(cuid())
  userId      String
  title       String
  description String? @db.Text
  photoUrls   String[]
  category    String?
  featured    Boolean @default(false)
  order       Int     @default(0)
  visible     Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Testimonial {
  id        String  @id @default(cuid())
  userId    String
  clientId  String?
  clientName String
  rating    Int     // 1-5
  comment   String? @db.Text
  approved  Boolean @default(false)
  visible   Boolean @default(true)

  createdAt DateTime @default(now())
}

model PortfolioLead {
  id        String   @id @default(cuid())
  userId    String
  name      String
  whatsapp  String?
  email     String?
  message   String?  @db.Text
  source    String?  // URL da peça que chamou atenção
  read      Boolean  @default(false)

  createdAt DateTime @default(now())
}
